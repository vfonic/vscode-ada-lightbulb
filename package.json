{
  "name": "ada-lightbulb",
  "displayName": "Ada Lightbulb",
  "description": "The only git GUI you'll ever need.",
  "version": "0.4.0",
  "icon": "resources/icon.png",
  "license": "MIT",
  "publisher": "vfonic",
  "author": {
    "name": "Viktor Fonic",
    "email": "viktor.fonic@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/vfonic/vscode-ada-lightbulb/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vfonic/vscode-ada-lightbulb.git"
  },
  "engines": {
    "vscode": "^1.46.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "my-fancy-view",
          "title": "Fancy View",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "my-fancy-view": [
        {
          "type": "webview",
          "id": "my-webview",
          "name": "Webview"
        }
      ]
    },
    "commands": [
      {
        "title": "Ada Lightbulb: Open graph",
        "command": "ada-lightbulb.view"
      }
    ]
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "pretest": "npm run compile-tests",
    "test": "vscode-test",
    "package": "npm run check-types && node esbuild.js --production",
    "lint": "eslint src/",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.46.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "npm-run-all2": "^8.0.4",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
